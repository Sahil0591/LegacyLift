# LegacyLift Frontend — Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.

# Backend REST API base URL (no trailing slash)
# Azure App Service URL: https://<AZURE_APP_NAME>.azurewebsites.net
NEXT_PUBLIC_API_URL=https://your-app-name.azurewebsites.net

# Backend WebSocket URL — must start with ws:// or wss://
# Azure App Service URL: wss://<AZURE_APP_NAME>.azurewebsites.net
NEXT_PUBLIC_WEBSOCKET_URL=wss://your-app-name.azurewebsites.net

# Set to "true" to load demo COBOL fixtures instead of hitting the real API
NEXT_PUBLIC_DEMO_MODE=false

# NOTE: Venice AI is no longer configured in the frontend. All LLM calls —
# including the "Regenerate" flow — are proxied through the backend's
# /llm/migrate, /llm/review and /llm/tests endpoints. Set VENICE_API_KEY on the
# server (see server/.env.example), never here.
