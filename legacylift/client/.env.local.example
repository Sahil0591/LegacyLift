# LegacyLift Frontend - Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.

# ── Clerk Auth ────────────────────────────────────────────────────────────────
# Get from: Clerk Dashboard → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your-publishable-key-here
CLERK_SECRET_KEY=sk_test_your-secret-key-here

# Clerk routing - must match the pages in app/sign-in and app/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/demo
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/demo

# ── Backend API ───────────────────────────────────────────────────────────────
# REST API base URL (no trailing slash)
# Azure App Service: https://<AZURE_APP_NAME>.azurewebsites.net
# Render:            https://<RENDER_SERVICE_NAME>.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# WebSocket URL - must start with ws:// or wss://
NEXT_PUBLIC_WEBSOCKET_URL=ws://localhost:8000

# ── Demo mode ─────────────────────────────────────────────────────────────────
# Set to "true" to load demo COBOL fixtures instead of hitting the real API
NEXT_PUBLIC_DEMO_MODE=false

# NOTE: Venice AI is no longer configured in the frontend. All LLM calls -
# including the "Regenerate" flow - are proxied through the backend's
# /llm/migrate, /llm/review and /llm/tests endpoints. Set VENICE_API_KEY on the
# server (see server/.env.example), never here.

# ── GitHub repo import (optional) ─────────────────────────────────────────────
# Used only by /api/analyze when importing a PUBLIC repo by URL. Raises GitHub's
# API rate limit from 60/hr (unauthenticated) to 5,000/hr. Server-side only -
# do NOT add a NEXT_PUBLIC_ prefix or the secret ends up in the browser bundle.
# A classic PAT with no scopes is enough (public read). Configured in Vercel prod.
GITHUB_TOKEN=ghp_your-github-token-here
