# LegacyLift Frontend — Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.

# Backend REST API base URL (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:8080

# Backend WebSocket URL — must start with ws:// or wss://
NEXT_PUBLIC_WEBSOCKET_URL=ws://localhost:8765

# Set to "true" to load demo COBOL fixtures instead of hitting the real API
NEXT_PUBLIC_DEMO_MODE=true
