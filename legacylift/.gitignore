# =============================================================================
# LegacyLift — .gitignore
# =============================================================================

# --- Environment & Secrets ---
.env
.env.local
.env.*.local
*.pem
*.key
secrets/

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
MANIFEST
wheels/
share/python-wheels/
pip-wheel-metadata/

# --- Virtual Environments ---
.venv/
venv/
env/
ENV/
.python-version

# --- Testing & Coverage ---
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
*.cover
nosetests.xml
junit*.xml
test-results/
.tox/
.nox/

# --- Type Checking ---
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/
.pyre/

# --- Database ---
*.db
*.sqlite
*.sqlite3
legacylift.db
legacylift.db-shm
legacylift.db-wal

# --- Logs ---
*.log
logs/
*.out

# --- IDE & Editors ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb

# --- Node (if a frontend is added later) ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.next/
out/
.nuxt/

# --- Docker ---
.dockerignore
docker-compose.override.yml

# --- Fly.io ---
.fly/

# --- Temporary & Generated Files ---
tmp/
temp/
legacylift_tests/
*.tmp
*.bak
*.orig
*.patch

# --- Build Artifacts ---
*.whl
*.tar.gz
*.zip

# --- OS ---
.DS_Store
.AppleDouble
.LSOverride
ehthumbs.db
ehthumbs_vista.db
[Dd]esktop.ini
$RECYCLE.BIN/
*.lnk
