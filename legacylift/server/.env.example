# LegacyLift Server — Environment Variables
# Copy this file to .env and fill in your values.

# ── Mode ──────────────────────────────────────────────────────────────────────
# Set to "true" to skip real LLM calls and use demo stubs (safe for demos/CI).
DEMO_MODE=true

# Set to "true" to auto-approve every migration chunk without human review.
AUTO_APPROVE=false

# ── Venice AI ─────────────────────────────────────────────────────────────────
# All LLM calls (Layers 0-4) go through the Venice API.
VENICE_API_KEY=your-venice-api-key-here
VENICE_BASE_URL=https://api.venice.ai/api/v1
VENICE_MODEL=openai-gpt-52-codex

# Retry behaviour for the LLM client.
LLM_MAX_RETRIES=3
LLM_RETRY_DELAY=2

# ── Clerk Auth ────────────────────────────────────────────────────────────────
# Get from: Clerk Dashboard → API Keys → "Advanced" → JWKS URL
# Format: https://<your-instance>.clerk.accounts.dev/.well-known/jwks.json
CLERK_JWKS_URL=https://your-instance.clerk.accounts.dev/.well-known/jwks.json

# --- Database ---
# Shared SQLAlchemy DATABASE_URL for BOTH the GitHub overlay/ownership review
# tables AND (when DEMO_MODE=false) workbench project/lesson/user-limit
# storage — same engine, tables namespaced workbench_* vs. the overlay
# tables, no collision. Replaces the old SQLITE_DB_PATH variable (removed).
#
# Local development: defaults to a local SQLite file under server/.data/.
# Production (DEMO_MODE=false): point this at a managed Postgres instance —
# Neon (https://neon.tech) recommended. Example:
#   DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.neon.tech/dbname
# Prefer Neon's *direct* (non-pooled) connection string. If only the pooled
# (pgbouncer) string is available, db/session.py automatically disables
# asyncpg's prepared-statement cache for any postgresql:// URL, so no extra
# configuration is needed — just marginally lower performance on pooled
# connections.
#
# The browser never talks to Neon/Postgres directly — only FastAPI holds
# DATABASE_URL, and every row is scoped by owner_id derived from the
# verified Clerk JWT (see CLERK_JWKS_URL below), never from client input.
DATABASE_URL=sqlite+aiosqlite:///./.data/legacylift.db

# --- GitHub App ingestion ---
# Create a GitHub App, subscribe it to installation, push, and pull_request events,
# and point the webhook URL at /github/webhook.
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- GitHub overlay API ---
# Optional temporary bearer token for PATCH /github/overlay/annotation/{id}.
# Mutations always require X-LegacyLift-User. Outside DEMO_MODE, configure this
# token until full GitHub user auth is wired.
OVERLAY_DEV_AUTH_TOKEN=

# ── Project storage ───────────────────────────────────────────────────────────
# DEMO_MODE=true  -> projects are stored in this JSON file.
STORAGE_FILE=legacylift_data.json
# DEMO_MODE=false -> projects are stored via DATABASE_URL instead (see the
# Database section above). Point DATABASE_URL at a managed Postgres instance
# in production, or projects will be lost on every redeploy of an ephemeral
# filesystem (see render.yaml for the Render-specific caveat).

# ── Required when DEMO_MODE=false ───────────────────────────────────────────────
# The server validates VENICE_API_KEY, VENICE_MODEL, VENICE_BASE_URL,
# CLERK_JWKS_URL, and DATABASE_URL are all set (and DATABASE_URL is
# well-formed) at startup, and refuses to start otherwise.
#
# To import existing local data (legacylift_data.json / an old local SQLite
# store) into Neon: python -m scripts.migrate_to_neon --source-json
# legacylift_data.json --target-database-url <neon-url> --dry-run (see
# scripts/migrate_to_neon.py --help for the full set of options).
