# LegacyLift Server — Environment Variables
# Copy this file to .env and fill in your values.

# ── Mode ──────────────────────────────────────────────────────────────────────
# Set to "true" to skip real LLM calls and use demo stubs (safe for demos/CI).
DEMO_MODE=true

# Set to "true" to auto-approve every migration chunk without human review.
AUTO_APPROVE=false

# ── Venice AI ─────────────────────────────────────────────────────────────────
# All LLM calls (Layers 0-4) go through the Venice API.
VENICE_API_KEY=your-venice-api-key-here
VENICE_BASE_URL=https://api.venice.ai/api/v1
VENICE_MODEL=openai-gpt-52-codex

# Retry behaviour for the LLM client.
LLM_MAX_RETRIES=3
LLM_RETRY_DELAY=2

# --- Clerk Auth ---
# Get from: Clerk Dashboard → API Keys → "Advanced" → JWKS URL
# Format: https://<your-instance>.clerk.accounts.dev/.well-known/jwks.json
CLERK_JWKS_URL=https://your-instance.clerk.accounts.dev/.well-known/jwks.json
