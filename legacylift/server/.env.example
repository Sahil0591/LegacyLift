# LegacyLift Server — Environment Variables
# Copy this file to .env and fill in your values.

# ── Mode ──────────────────────────────────────────────────────────────────────
# Set to "true" to skip real LLM calls and use demo stubs (safe for demos/CI).
DEMO_MODE=true

# Set to "true" to auto-approve every migration chunk without human review.
AUTO_APPROVE=false

# ── LLM Client (migration generator — Steps 5/6) ─────────────────────────────
# For Venice AI: set OPENAI_API_KEY to your Venice key and point base_url at Venice.
# For standard OpenAI: set OPENAI_API_KEY and leave OPENAI_BASE_URL unset.
OPENAI_API_KEY=your-venice-api-key-here
OPENAI_BASE_URL=https://api.venice.ai/api/v1
OPENAI_MODEL=kimi-k2-5

# Retry behaviour for the LLM client.
LLM_MAX_RETRIES=3
LLM_RETRY_DELAY=2

# ── Venice AI (Layer 0 business-rule extraction — direct HTTP) ────────────────
VENICE_API_KEY=your-venice-api-key-here
VENICE_BASE_URL=https://api.venice.ai/api/v1
VENICE_MODEL=kimi-k2-5
