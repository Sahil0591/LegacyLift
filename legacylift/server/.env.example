# LegacyLift Server — Environment Variables
# Copy this file to .env and fill in your values.

# ── Mode ──────────────────────────────────────────────────────────────────────
# Set to "true" to skip real LLM calls and use demo stubs (safe for demos/CI).
DEMO_MODE=true

# Set to "true" to auto-approve every migration chunk without human review.
AUTO_APPROVE=false

# ── Venice AI ─────────────────────────────────────────────────────────────────
# All LLM calls (Layers 0-4) go through the Venice API.
VENICE_API_KEY=your-venice-api-key-here
VENICE_BASE_URL=https://api.venice.ai/api/v1
VENICE_MODEL=openai-gpt-52-codex

# Retry behaviour for the LLM client.
LLM_MAX_RETRIES=3
LLM_RETRY_DELAY=2

# ── Clerk Auth ────────────────────────────────────────────────────────────────
# Get from: Clerk Dashboard → API Keys → "Advanced" → JWKS URL
# Format: https://<your-instance>.clerk.accounts.dev/.well-known/jwks.json
CLERK_JWKS_URL=https://your-instance.clerk.accounts.dev/.well-known/jwks.json

# --- Database (GitHub overlay / ownership review persistence) ---
# Local development stores durable analysis records under server/.data/.
# Use postgresql+asyncpg://... in production.
DATABASE_URL=sqlite+aiosqlite:///./.data/legacylift.db

# --- GitHub App ingestion ---
# Create a GitHub App, subscribe it to installation, push, and pull_request events,
# and point the webhook URL at /github/webhook.
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- GitHub overlay API ---
# Optional temporary bearer token for PATCH /github/overlay/annotation/{id}.
# Mutations always require X-LegacyLift-User. Outside DEMO_MODE, configure this
# token until full GitHub user auth is wired.
OVERLAY_DEV_AUTH_TOKEN=

# ── Project storage ───────────────────────────────────────────────────────────
# DEMO_MODE=true  -> projects are stored in this JSON file.
STORAGE_FILE=legacylift_data.json
# DEMO_MODE=false -> projects are stored in this SQLite database instead.
# Point this at a persistent disk in production or projects will be lost on
# every redeploy (see render.yaml for the Render-specific caveat).
SQLITE_DB_PATH=legacylift.db

# ── Required when DEMO_MODE=false ───────────────────────────────────────────────
# The server validates VENICE_API_KEY, VENICE_MODEL, VENICE_BASE_URL, and
# CLERK_JWKS_URL are all set at startup and refuses to start otherwise.
