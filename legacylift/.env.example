# =============================================================================
# LegacyLift - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit .env to git (it is already in .gitignore).
#
# Usage: cp .env.example .env   (Linux/Mac)
#        copy .env.example .env  (Windows)
# =============================================================================

# --- Venice / LLM Configuration ---
# Venice exposes an OpenAI-compatible chat completions API.
VENICE_API_KEY=your-venice-api-key

# Which Venice model to use for code migration and review.
VENICE_MODEL=qwen-2.5-coder-32b

# Optional override for Venice's OpenAI-compatible base URL.
VENICE_BASE_URL=https://api.venice.ai/api/v1

# LLM provider selection.
LLM_PROVIDER=venice

# --- Demo / Debug Mode ---
# When DEMO_MODE=true, every LLM prompt and response is printed to console.
# Also enables synthetic placeholder data so the pipeline runs without
# a real Venice key. Set to false in production.
DEMO_MODE=true

# --- API Server ---
# Host and port for the FastAPI server.
API_HOST=0.0.0.0
API_PORT=8000

# --- Database ---
# SQLite path for local project metadata storage.
# For production, replace with postgresql://user:pass@host/db
DATABASE_URL=sqlite+aiosqlite:///./legacylift.db

# --- Pipeline Behaviour ---
# Maximum number of LLM retries before giving up on a chunk.
LLM_MAX_RETRIES=3

# Seconds to wait between LLM retries (exponential backoff base).
LLM_RETRY_DELAY=2

# Automatically approve all chunks without human review (for demos only!).
AUTO_APPROVE=false

# --- WebSocket ---
# Ping interval in seconds to keep WebSocket connections alive.
WS_PING_INTERVAL=30

# --- Azure Deployment (only needed when deploying to Azure App Service) ---
# The App Service name you chose during az webapp create.
AZURE_APP_NAME=your-app-name-here

# The Resource Group that contains the App Service and Container Registry.
AZURE_RESOURCE_GROUP=your-resource-group
